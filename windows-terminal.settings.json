        },
        {
            "id": "Terminal.FocusPaneRight",
            "keys": "alt+right"
        },
        {
            "id": "Terminal.PasteFromClipboard",
            "keys": "ctrl+v"
        },
        {
            "id": "Terminal.DuplicatePaneAuto",
            "keys": "alt+shift+d"
        },
        {
            "id": "Terminal.FocusPaneLeft",
            "keys": "alt+left"
        },
        {
            "id": "Terminal.FocusPaneDown",
            "keys": "alt+down"
